{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Build Orderbook",
            "command": "/usr/bin/clang++",
            "args": [
                "-fcolor-diagnostics",
                "-fansi-escape-codes",
                "-g",
                "-std=c++20",
                "${workspaceFolder}/Orderbook.cpp",
                "-o",
                "${workspaceFolder}/Orderbook"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ],
    "version": "2.0.0"
}
